[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "Generated with the Austial CLI (`austial new`)."
requires-python = ">=3.11"
dependencies = [
    "austial>=0.1.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.2.0",
    "pytest-asyncio>=0.23.0",
    "httpx>=0.27.0",
]
{% if austial_source_path %}

[tool.uv.sources]
austial = { path = "{{ austial_source_path }}", editable = true }
{% endif %}

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
pythonpath = ["."]
python_files = ["*_spec.py", "test_*.py", "*_test.py"]
